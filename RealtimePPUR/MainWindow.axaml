<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RealtimePPUR.MainWindow"
        Title="RealtimePPUR"
        Width="420"
        Height="160"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"

        CanResize="True">

  <Window.Styles>
    <Styles>

      <!-- ラベル（紫系） -->
      <Style Selector="TextBlock.label">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif"/>
        <Setter Property="Foreground" Value="#A78BFA"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LetterSpacing" Value="1.5"/>
      </Style>

      <!-- 数値（白） -->
      <Style Selector="TextBlock.value">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif"/>
        <Setter Property="Foreground" Value="#F1F5F9"/>
        <Setter Property="FontWeight" Value="Bold"/>
      </Style>

      <!-- 小ラベル（グレー） -->
      <Style Selector="TextBlock.sublabel">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif"/>
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="FontWeight" Value="Normal"/>
      </Style>

    </Styles>
  </Window.Styles>

  <!-- グラス背景 -->
  <Border CornerRadius="14" ClipToBounds="True">

    <Panel>

      <!-- 背景グラデーション -->
      <Border>
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#1E1B4B" Offset="0"/>
            <GradientStop Color="#0F172A" Offset="0.6"/>
            <GradientStop Color="#1E1035" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
      </Border>

      <!-- グロー装飾（右上） -->
      <Ellipse Width="180" Height="80" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-30,-40,0" Opacity="0.18">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#7C3AED" Offset="0"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>

      <!-- グロー装飾（左下） -->
      <Ellipse Width="120" Height="60" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-20,0,0,-20" Opacity="0.12">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#6D28D9" Offset="0"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>

      <!-- ボーダー（グラス縁） -->
      <Border CornerRadius="14" BorderThickness="1">
        <Border.BorderBrush>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#4C1D9560" Offset="0"/>
            <GradientStop Color="#1E293B40" Offset="1"/>
          </LinearGradientBrush>
        </Border.BorderBrush>
      </Border>

      <!-- メインコンテンツ -->
      <Grid Margin="14,10,14,10" RowDefinitions="*,Auto,*" ColumnDefinitions="*,1,Auto">

        <!-- ===== 左ペイン ===== -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" RowDefinitions="*,Auto,*">

          <!-- 上段: SR / IFFC -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

            <!-- SR -->
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBlock Classes="label" Text="SR" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock x:Name="SrValue" Classes="value" Text="6.49" FontSize="22" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 縦区切り -->
            <Rectangle Width="1" Height="18" VerticalAlignment="Center" Opacity="0.25">
              <!-- <Rectangle.Fill>
                <SolidColorBrush Color="#A78BFA"/>
              </Rectangle.Fill> -->
            </Rectangle>

            <!-- IFFC -->
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBlock Classes="label" Text="IFFC" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock x:Name="IffcValue" Classes="value" Text="465" FontSize="22" VerticalAlignment="Center"/>
            </StackPanel>

          </StackPanel>

          <!-- 中段区切り -->
          <Rectangle Grid.Row="1" Height="1" Opacity="0.12" Margin="0,2">
            <!-- <Rectangle.Fill>
              <SolidColorBrush Color="#A78BFA"/>
            </Rectangle.Fill> -->
          </Rectangle>

          <!-- 中段: ヒット数 (300 / 100 / 50) 均等幅 -->
          <UniformGrid Grid.Row="2" Rows="1" Columns="3" VerticalAlignment="Center" Margin="0,2,0,200">

            <!-- 300 -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="2">
              <TextBlock x:Name="Count300" Classes="value" Text="0" FontSize="30" HorizontalAlignment="Center"/>
              <Border Height="3" HorizontalAlignment="Center" Width="22" CornerRadius="2">
                <Border.Background>
                  <SolidColorBrush Color="#60A5FA"/>
                </Border.Background>
              </Border>
            </StackPanel>

            <!-- 100 -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="2">
              <TextBlock x:Name="Count100" Classes="value" Text="0" FontSize="30" HorizontalAlignment="Center"/>
              <Border Height="3" HorizontalAlignment="Center" Width="22" CornerRadius="2">
                <Border.Background>
                  <SolidColorBrush Color="#FBBF24"/>
                </Border.Background>
              </Border>
            </StackPanel>

            <!-- 50 -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="2">
              <TextBlock x:Name="Count50" Classes="value" Text="0" FontSize="30" HorizontalAlignment="Center"/>
              <Border Height="3" HorizontalAlignment="Center" Width="22" CornerRadius="2">
                <Border.Background>
                  <SolidColorBrush Color="#F87171"/>
                </Border.Background>
              </Border>
            </StackPanel>

          </UniformGrid>

        </Grid>

        <!-- ===== 縦区切り ===== -->
        <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="1" Opacity="0.15" Margin="12,4">
          <!-- <Rectangle.Fill>
            <SolidColorBrush Color="#A78BFA"/>
          </Rectangle.Fill> -->
        </Rectangle>

        <!-- ===== 右ペイン ===== -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" RowDefinitions="*,Auto,*" Margin="4,0,0,0">

          <!-- 上段: pp -->
          <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="3">
            <TextBlock x:Name="PpValue" Classes="value" Text="465" FontSize="34" FontWeight="ExtraBold" VerticalAlignment="Bottom"/>
            <TextBlock Classes="label" Text="pp" FontSize="16" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
          </StackPanel>

          <!-- 中段区切り -->
          <Rectangle Grid.Row="1" Height="1" Opacity="0.12" Margin="0,2">
            <!-- <Rectangle.Fill>
              <SolidColorBrush Color="#A78BFA"/>
            </Rectangle.Fill> -->
          </Rectangle>

          <!-- 下段: UR -->
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
            <TextBlock Classes="label" Text="UR" FontSize="13" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
            <TextBlock x:Name="UrValue" Classes="value" Text="136" FontSize="30" FontWeight="ExtraBold" VerticalAlignment="Bottom"/>
          </StackPanel>
        </Grid>
      </Grid>

      <!-- フッター帯: Offset / Avg -->
      <Border VerticalAlignment="Bottom" Padding="14,14,14,6" CornerRadius="0,0,14,14">
        <Border.Background>
          <SolidColorBrush Color="#0D0B1E" Opacity="0"/>
        </Border.Background>

        <Grid ColumnDefinitions="Auto,Auto,*,Auto">

          <TextBlock Grid.Column="0" Classes="label" Text="Offset" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>

          <TextBlock x:Name="OffsetValue" Grid.Column="1" Classes="value" Text="-3" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="12,0,0,0" VerticalAlignment="Center">
            <TextBlock Classes="sublabel" Text="Avg" FontSize="10" VerticalAlignment="Center"/>
            <TextBlock x:Name="AvgValue" Classes="sublabel" Text="2.96ms" FontSize="10" Foreground="#94A3B8"  VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

    </Panel>
  </Border>

</Window>
