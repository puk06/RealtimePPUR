<Window xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:Avalonia.Notification.Controls;assembly=Notification.Avalonia"
	x:Class="RealtimePPUR.MainWindow"
	Title="RealtimePPUR"
	Width="430"
	Height="170"
	Background="Transparent"
	TransparencyLevelHint="AcrylicBlur"
	FontFamily="avares://RealtimePPUR/Assets/Fonts#Oxanium"
	CanResize="True"
	ExtendClientAreaChromeHints="NoChrome"
	ExtendClientAreaToDecorationsHint="True"
	PointerPressed="OnPointerPressed"
	PointerMoved="OnPointerMoved"
	PointerReleased="OnPointerReleased"
	Loaded="OnLoaded">

	<Window.Styles>
		<Styles>

			<!-- ラベル（紫系） -->
			<Style Selector="TextBlock.label">
				<Setter Property="Foreground" Value="#A78BFA"/>
				<Setter Property="FontWeight" Value="SemiBold"/>
				<Setter Property="LetterSpacing" Value="1.5"/>
			</Style>

			<!-- 数値（白） -->
			<Style Selector="TextBlock.value">
				<Setter Property="Foreground" Value="#F1F5F9"/>
				<Setter Property="FontWeight" Value="Bold"/>
			</Style>

			<!-- 小ラベル（グレー） -->
			<Style Selector="TextBlock.sublabel">
				<Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif"/>
				<Setter Property="Foreground" Value="#64748B"/>
				<Setter Property="FontWeight" Value="Normal"/>
			</Style>

			<Style Selector="NotificationCard">
				<Setter Property="Background" Value="#2B2B2B"/>
				<Setter Property="BorderBrush" Value="#444444"/>
			</Style>
		</Styles>
	</Window.Styles>

	<Border CornerRadius="14" ClipToBounds="True">

		<Panel Background="Black">
			<!-- メインコンテンツ -->
			<StackPanel Orientation="Vertical" Margin="14,7,14,7">
				<Grid x:Name="RealtimeSR" ColumnDefinitions="*,*,*">
					<StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
						<TextBlock Classes="label" Text="SR" FontSize="21" VerticalAlignment="Center"/>
						<TextBlock x:Name="SrValue" Classes="value" Text="0" FontSize="26" VerticalAlignment="Center"/>
					</StackPanel>

					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
						<TextBlock x:Name="IffcLabel" Classes="label" Text="IFFC" FontSize="21" VerticalAlignment="Center"/>
						<TextBlock x:Name="IffcValue" Classes="value" Text="0" FontSize="26" VerticalAlignment="Center"/>
					</StackPanel>
				</Grid>

				<Grid x:Name="RealtimePP" ColumnDefinitions="1.7*,*">
					<UniformGrid Grid.Column="0" Columns="3" ColumnSpacing="5" VerticalAlignment="Center">
						<StackPanel Orientation="Vertical" HorizontalAlignment="Center" Spacing="2">
							<TextBlock x:Name="Count300" Classes="value" Text="0" FontSize="27" HorizontalAlignment="Center"/>
							<Border Height="3" HorizontalAlignment="Center" Width="22" CornerRadius="2">
								<Border.Background>
									<SolidColorBrush Color="#60A5FA"/>
								</Border.Background>
							</Border>
						</StackPanel>

						<StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" Spacing="2">
							<TextBlock x:Name="Count100" Classes="value" Text="0" FontSize="27" HorizontalAlignment="Center"/>
							<Border Height="3" HorizontalAlignment="Center" Width="22" CornerRadius="2">
								<Border.Background>
									<SolidColorBrush Color="#FBBF24"/>
								</Border.Background>
							</Border>
						</StackPanel>

						<StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Center" Spacing="2">
							<TextBlock x:Name="CountMiss" Classes="value" Text="0" FontSize="27" HorizontalAlignment="Center"/>
							<Border Height="3" HorizontalAlignment="Center" Width="22" CornerRadius="2">
								<Border.Background>
									<SolidColorBrush Color="#F87171"/>
								</Border.Background>
							</Border>
						</StackPanel>
					</UniformGrid>

					<Panel Grid.Column="1">
						<StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="3">
							<TextBlock x:Name="PpValue" Classes="value" Text="0" FontSize="42" FontWeight="ExtraBold" VerticalAlignment="Center"/>
							<TextBlock Classes="label" Text="pp" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
						</StackPanel>
					</Panel>
				</Grid>

				<Grid x:Name="OffsetHelper" Grid.Row="1" ColumnDefinitions="1.4*,*">
					<Grid RowDefinitions="*,Auto" VerticalAlignment="Center">
						<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
							<TextBlock Classes="label" Text="Offset" FontSize="27" VerticalAlignment="Center"/>
							<TextBlock x:Name="OffsetValue" Classes="value" Text="0" FontSize="35" VerticalAlignment="Center"/>
						</StackPanel>

						<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
							<TextBlock Classes="label" Text="Avg" FontSize="18" VerticalAlignment="Center"/>
							<TextBlock x:Name="AvgValue" Classes="value" Text="0ms" FontSize="19" VerticalAlignment="Center"/>
						</StackPanel>
					</Grid>
					
					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
						<TextBlock Classes="label" Text="UR" FontSize="34" VerticalAlignment="Center"/>
						<TextBlock x:Name="UrValue" Classes="value" Text="0" FontSize="45" VerticalAlignment="Center"/>
					</StackPanel>
				</Grid>
			</StackPanel>

			<controls:NotificationMessageContainer x:Name="NotificationMessageContainer"/>
		</Panel>
	</Border>
</Window>
