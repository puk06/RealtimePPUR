<Window xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	x:Class="RealtimePPUR.InGameOverlay"
	Title="RealtimePPUR - InGameOverlay"
	Background="Transparent"
	TransparencyLevelHint="AcrylicBlur"
	FontFamily="avares://RealtimePPUR/Assets/Fonts#Oxanium"
    ExtendClientAreaToDecorationsHint="True"
	SizeToContent="WidthAndHeight"
	ExtendClientAreaChromeHints="NoChrome"
	Closing="OnClosing">
	<Border Background="Transparent">
        <TextBlock x:Name="IngameOverlayValue" Text="" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="24" Margin="5"/>
    </Border>
</Window>
